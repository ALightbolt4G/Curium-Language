{
  "name": "Curium",
  "scopeName": "source.cm",
  "fileTypes": ["cm", "curium"],
  "patterns": [
    {
      "name": "comment.line.double-slash.curium",
      "match": "//.*$"
    },
    {
      "name": "comment.block.curium",
      "begin": "/\\*",
      "end": "\\*/"
    },
    {
      "name": "string.quoted.double.curium",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.curium",
          "match": "\\\\."
        },
        {
          "name": "variable.interpolation.curium",
          "match": "\\{[^\\}]+\\}"
        }
      ]
    },
    {
      "name": "keyword.control.curium",
      "match": "\\b(fn|let|mut|if|else|while|for|return|match|break|continue|dyn|try|catch|throw|spawn|join|reactor|pub|import|require|gc|print|println|input|strnum|impl|struct|enum|union|trait|arena|manual|rc)\\b"
    },
    {
      "name": "storage.type.curium",
      "match": "\\b(int|float|string|bool|void|i8|u8|i16|i32|i64|u16|u32|u64|f32|f64|usize|Option|Result|array|slice|map)\\b"
    },
    {
      "name": "constant.language.curium",
      "match": "\\b(true|false|Ok|Err|Some|None)\\b"
    },
    {
      "name": "constant.numeric.curium",
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
    },
    {
      "name": "keyword.operator.curium",
      "match": "(\\+|\\-|\\*|/|%|==|!=|<|>|<=|>=|&&|\\|\\||!|&|\\||\\^|\\?|\\?\\?|->|=>|\\.|:|:=|@|\\$)"
    },
    {
      "name": "meta.function.curium",
      "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captures": {
        "1": { "name": "keyword.control.curium" },
        "2": { "name": "entity.name.function.curium" }
      }
    }
  ]
}
