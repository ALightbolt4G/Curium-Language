# GitHub Linguist only recognizes languages in its grammar list; map .cm to C for stats/highlighting.
*.cm linguist-language=C

# Source Files (Ensure they are not marked as generated)
src/**/*.c linguist-generated=false
src/**/*.h linguist-generated=false

# Truly Generated Files
curium_out.c linguist-generated=true
build/ linguist-generated=true

# Tests (Should be recognized as code, not docs)
tests/*.cm linguist-documentation=false
tests/*.cm linguist-detectable=true
