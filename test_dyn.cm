fn main() {
    mut x = 10;
    mut y = 20;

    mut op = "max";

    dyn op in (
        "+" => { return x + y; },
        "*" => { return x * y; },
        "avg" => { return (x + y) / 2; }
    ) dyn(op == "max") {
        return x > y ? x : y;
    } dyn(op == "min") {
        return x < y ? x : y;
    } dyn($) {
        println("Unknown operator!");
        return 0;
    };

    println(x op y);
}
